# ============================================================
# king-remind Docker 部署环境变量配置模板
# 使用方法：复制此文件为 .env 并填写你的配置
#   cp .env.example .env
# ============================================================

# ==================== 通用设置 ====================
# API 服务开关（Docker 部署建议开启）
KING_API_ENABLED=true
# API 服务端口
KING_API_PORT=33333
# API 访问令牌（留空则不鉴权，生产环境建议设置）
KING_API_TOKEN=
# 是否允许环境变量覆盖数据库中已有的配置（默认 false，仅写入空配置）
KING_CONFIG_OVERRIDE=false

# ==================== 邮件通知 ====================
KING_EMAIL_ENABLED=false
KING_EMAIL_SMTP_HOST=smtp.example.com
KING_EMAIL_SMTP_PORT=587
KING_EMAIL_SMTP_SECURE=false
KING_EMAIL_SMTP_USER=user@example.com
KING_EMAIL_SMTP_PASS=your-password
KING_EMAIL_FROM=user@example.com
# 多个收件人用英文逗号分隔
KING_EMAIL_TO=to1@example.com,to2@example.com

# ==================== Telegram 通知 ====================
KING_TELEGRAM_ENABLED=false
KING_TELEGRAM_BOT_TOKEN=123456:ABC-DEF
KING_TELEGRAM_CHAT_ID=123456789
# 代理地址（可选，如需翻墙访问 Telegram API）
KING_TELEGRAM_PROXY_URL=

# ==================== 企业微信通知 ====================
KING_WECHAT_WORK_ENABLED=false
KING_WECHAT_WORK_CORP_ID=ww1234567890
KING_WECHAT_WORK_CORP_SECRET=your-corp-secret
KING_WECHAT_WORK_AGENT_ID=1000001
# 接收人，@all 为全部成员
KING_WECHAT_WORK_TO_USER=@all

# ==================== 企微群消息推送 Webhook ====================
KING_WECHAT_WORK_WEBHOOK_ENABLED=false
KING_WECHAT_WORK_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# ==================== 微信测试公众号 ====================
KING_WECHAT_TEST_ENABLED=false
KING_WECHAT_TEST_APP_ID=wx1234567890
KING_WECHAT_TEST_APP_SECRET=your-app-secret
KING_WECHAT_TEST_TO_OPENID=oXXXX

# ==================== 微信机器人 ====================
# 启用后需通过 API 扫码登录
# 扫码接口：POST http://localhost:33333/api/wechat-bot/qrcode
# 状态查询：GET  http://localhost:33333/api/wechat-bot/status
KING_WECHAT_BOT_ENABLED=false

# ==================== 钉钉群机器人 ====================
KING_DINGTALK_ENABLED=false
KING_DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
# 加签密钥（可选）
KING_DINGTALK_SECRET=

# ==================== 飞书群机器人 ====================
KING_FEISHU_ENABLED=false
KING_FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# ==================== Bark (iOS 推送) ====================
KING_BARK_ENABLED=false
KING_BARK_SERVER_URL=https://api.day.app
KING_BARK_KEY=your-bark-key

# ==================== Discord Webhook ====================
KING_DISCORD_ENABLED=false
KING_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# ==================== 自定义 Webhook ====================
KING_WEBHOOK_ENABLED=false
KING_WEBHOOK_URL=https://your-server.com/webhook