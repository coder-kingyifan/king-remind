    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@element-plus/icons-vue": "^2.3.1",
    "@types/nodemailer": "^6.4.17",
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "element-plus": "^2.9.1",
    "pinia": "^2.3.0",
    "sass": "^1.83.4",
    "typescript": "^5.7.3",
