    "preview": "electron-vite preview",
    "pack": "electron-vite build && electron-builder --win --config",
    "pack:dir": "electron-vite build && electron-builder --win --dir --config"
  },
  "dependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.59.0",
